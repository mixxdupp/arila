# Node environment
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://arila:CHANGE_ME@localhost:5432/arila

# Session
SESSION_SECRET=generate-a-64-char-random-string-here
SESSION_MAX_AGE=86400000

# WebSocket
WS_HEARTBEAT_INTERVAL=30000

# Rate Limiting
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW=60000
RATE_LIMIT_GENERAL_MAX=100
RATE_LIMIT_GENERAL_WINDOW=3600000

# Purge
MESSAGE_QUEUE_TTL=86400000
